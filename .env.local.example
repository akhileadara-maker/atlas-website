# Clerk authentication keys — copy this file to ".env.local" and paste in YOUR keys.
# Get them free at https://dashboard.clerk.com  →  your app  →  "API Keys".
# The .env.local file is git-ignored, so your secret keys are NEVER pushed to GitHub.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where users land after signing in / signing up.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
